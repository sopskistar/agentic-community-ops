{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-community-ops.example/schemas/batch-analysis-input.json",
  "title": "Batch Analysis Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["projectId", "messages"],
  "properties": {
    "projectId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 25,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["content", "source"],
        "properties": {
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          },
          "source": {
            "type": "string",
            "enum": ["MANUAL", "X", "DISCORD", "TELEGRAM", "EMAIL", "OTHER"]
          },
          "authorName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        }
      }
    }
  }
}
